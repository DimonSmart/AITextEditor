@using AiTextEditor.Core.Model
@using Microsoft.AspNetCore.Components

<MudDialog Class="character-edit-dialog">
    <DialogContent>
        <MudForm @ref="form">
            <MudStack Spacing="3">
                <MudTextField @bind-Value="model.Name"
                              Label="Name"
                              Variant="MudBlazor.Variant.Outlined"
                              Margin="MudBlazor.Margin.Dense"
                              Immediate="true"
                              Required="true"
                              RequiredError="Name is required." />

                <MudSelect T="string"
                           @bind-Value="model.Gender"
                           Label="Gender"
                           Variant="MudBlazor.Variant.Outlined"
                           Margin="MudBlazor.Margin.Dense"
                           Required="true">
                    <MudSelectItem T="string" Value="@UnknownGender">unknown</MudSelectItem>
                    <MudSelectItem T="string" Value="@MaleGender">male</MudSelectItem>
                    <MudSelectItem T="string" Value="@FemaleGender">female</MudSelectItem>
                </MudSelect>

                <MudNumericField T="int?"
                                 @bind-Value="model.ImportanceLevel"
                                 Label="Importance level"
                                 Variant="MudBlazor.Variant.Outlined"
                                 Margin="MudBlazor.Margin.Dense"
                                 Min="1"
                                 Max="10"
                                 Immediate="true" />

                <MudTextField @bind-Value="model.Description"
                              Label="Description"
                              Variant="MudBlazor.Variant.Outlined"
                              Margin="MudBlazor.Margin.Dense"
                              Immediate="true"
                              Lines="4" />

                <MudExpansionPanels MultiExpansion="true" Elevation="0">
                    <MudExpansionPanel Text="@($"Aliases ({aliasRows.Count})")" Expanded="true">
                        <MudStack Spacing="2">
                            @foreach (var row in aliasRows)
                            {
                                <MudGrid Spacing="2" Class="character-edit-row">
                                    <MudItem xs="12" sm="4">
                                        <MudTextField @bind-Value="row.Alias"
                                                      Label="Alias"
                                                      Variant="MudBlazor.Variant.Outlined"
                                                      Margin="MudBlazor.Margin.Dense"
                                                      Immediate="true" />
                                    </MudItem>
                                    <MudItem xs="12" sm="7">
                                        <MudTextField @bind-Value="row.Example"
                                                      Label="Example"
                                                      Variant="MudBlazor.Variant.Outlined"
                                                      Margin="MudBlazor.Margin.Dense"
                                                      Immediate="true" />
                                    </MudItem>
                                    <MudItem xs="12" sm="1" Class="character-edit-row-action">
                                        <MudTooltip Text="Remove alias">
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Color="MudBlazor.Color.Error"
                                                           Size="MudBlazor.Size.Small"
                                                           OnClick="@(() => RemoveAlias(row))"
                                                           aria-label="Remove alias" />
                                        </MudTooltip>
                                    </MudItem>
                                </MudGrid>
                            }

                            <MudButton Variant="MudBlazor.Variant.Outlined"
                                       Color="MudBlazor.Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       OnClick="AddAlias">
                                Add alias
                            </MudButton>
                        </MudStack>
                    </MudExpansionPanel>

                    <MudExpansionPanel Text="Profile sections" Expanded="true">
                        <MudStack Spacing="2">
                            <MudTextField @bind-Value="model.Appearance"
                                          Label="Внешность"
                                          Variant="MudBlazor.Variant.Outlined"
                                          Margin="MudBlazor.Margin.Dense"
                                          Immediate="true"
                                          Lines="3" />

                            <MudTextField @bind-Value="model.BackgroundStatusEducation"
                                          Label="Происхождение, статус и образование"
                                          Variant="MudBlazor.Variant.Outlined"
                                          Margin="MudBlazor.Margin.Dense"
                                          Immediate="true"
                                          Lines="3" />

                            <MudTextField @bind-Value="model.PsychologicalProfile"
                                          Label="Психологический профиль"
                                          Variant="MudBlazor.Variant.Outlined"
                                          Margin="MudBlazor.Margin.Dense"
                                          Immediate="true"
                                          Lines="4" />

                            <MudTextField @bind-Value="model.SpeechAndCommunication"
                                          Label="Речь и манера общения"
                                          Variant="MudBlazor.Variant.Outlined"
                                          Margin="MudBlazor.Margin.Dense"
                                          Immediate="true"
                                          Lines="3" />

                            <div class="character-edit-section-title">Ключевые ролевые связки</div>
                            @foreach (var row in roleBondRows)
                            {
                                <MudGrid Spacing="2" Class="character-edit-row">
                                    <MudItem xs="12" sm="3">
                                        <MudTextField @bind-Value="row.CharacterName"
                                                      Label="Character"
                                                      Variant="MudBlazor.Variant.Outlined"
                                                      Margin="MudBlazor.Margin.Dense"
                                                      Immediate="true" />
                                    </MudItem>
                                    <MudItem xs="12" sm="3">
                                        <MudTextField @bind-Value="row.Role"
                                                      Label="Role"
                                                      Variant="MudBlazor.Variant.Outlined"
                                                      Margin="MudBlazor.Margin.Dense"
                                                      Immediate="true" />
                                    </MudItem>
                                    <MudItem xs="12" sm="5">
                                        <MudTextField @bind-Value="row.Description"
                                                      Label="Description"
                                                      Variant="MudBlazor.Variant.Outlined"
                                                      Margin="MudBlazor.Margin.Dense"
                                                      Immediate="true" />
                                    </MudItem>
                                    <MudItem xs="12" sm="1" Class="character-edit-row-action">
                                        <MudTooltip Text="Remove role bond">
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Color="MudBlazor.Color.Error"
                                                           Size="MudBlazor.Size.Small"
                                                           OnClick="@(() => RemoveRoleBond(row))"
                                                           aria-label="Remove role bond" />
                                        </MudTooltip>
                                    </MudItem>
                                </MudGrid>
                            }

                            <MudButton Variant="MudBlazor.Variant.Outlined"
                                       Color="MudBlazor.Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       OnClick="AddRoleBond">
                                Add role bond
                            </MudButton>
                        </MudStack>
                    </MudExpansionPanel>

                    </MudExpansionPanels>
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="MudBlazor.Variant.Text" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="MudBlazor.Variant.Filled"
                   Color="MudBlazor.Color.Primary"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="SaveAsync">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private const string UnknownGender = "unknown";
    private const string MaleGender = "male";
    private const string FemaleGender = "female";
    private static readonly HashSet<string> AllowedGenders = [UnknownGender, MaleGender, FemaleGender];

    private MudForm? form;
    private EditableCharacterDossier model = new();
    private readonly List<AliasRow> aliasRows = [];
    private readonly List<RoleBondRow> roleBondRows = [];

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public CharacterDossier? Dossier { get; set; }

    protected override void OnInitialized()
    {
        model = EditableCharacterDossier.From(Dossier);
        aliasRows.Clear();
        aliasRows.AddRange(model.AliasExamples.Select(item => new AliasRow(item.Key, item.Value)));
        roleBondRows.Clear();
        roleBondRows.AddRange(model.Profile.KeyRoleBonds?.Select(bond => new RoleBondRow(
            bond.CharacterName,
            bond.Role,
            bond.Description)) ?? []);
    }

    private void AddAlias()
    {
        aliasRows.Add(new AliasRow());
    }

    private void RemoveAlias(AliasRow row)
    {
        aliasRows.Remove(row);
    }

    private void AddRoleBond()
    {
        roleBondRows.Add(new RoleBondRow());
    }

    private void RemoveRoleBond(RoleBondRow row)
    {
        roleBondRows.Remove(row);
    }

    private async Task SaveAsync()
    {
        if (!AllowedGenders.Contains(model.Gender))
        {
            model.Gender = UnknownGender;
        }

        if (form is not null)
        {
            await form.Validate();
            if (!form.IsValid)
            {
                return;
            }
        }

        if (string.IsNullOrWhiteSpace(model.Name))
        {
            return;
        }

        MudDialog.Close(DialogResult.Ok(ToDossier()));
    }

    private CharacterDossier ToDossier()
    {
        var aliasExamples = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        foreach (var row in aliasRows)
        {
            if (string.IsNullOrWhiteSpace(row.Alias) || string.IsNullOrWhiteSpace(row.Example))
            {
                continue;
            }

            var alias = row.Alias.Trim();
            if (!aliasExamples.ContainsKey(alias))
            {
                aliasExamples[alias] = row.Example.Trim();
            }
        }

        var profile = CharacterProfile.Normalize(new CharacterProfile(
            model.Appearance,
            model.BackgroundStatusEducation,
            model.PsychologicalProfile,
            model.SpeechAndCommunication,
            roleBondRows
                .Where(row =>
                    !string.IsNullOrWhiteSpace(row.CharacterName)
                    && !string.IsNullOrWhiteSpace(row.Role)
                    && !string.IsNullOrWhiteSpace(row.Description))
                .Select(row => new CharacterRoleBond(
                    row.CharacterName.Trim(),
                    row.Role.Trim(),
                    row.Description.Trim()))
                .ToList()));

        return new CharacterDossier(
            model.CharacterId,
            model.Name.Trim(),
            model.Description.Trim(),
            aliasExamples.Keys.OrderBy(alias => alias, StringComparer.OrdinalIgnoreCase).ToList(),
            aliasExamples,
            model.Gender,
            CharacterImportance.NormalizeLevel(model.ImportanceLevel),
            profile);
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private sealed class EditableCharacterDossier
    {
        public string CharacterId { get; set; } = Guid.NewGuid().ToString("N");

        public string Name { get; set; } = string.Empty;

        public string Description { get; set; } = string.Empty;

        public string Gender { get; set; } = UnknownGender;

        public int? ImportanceLevel { get; set; }

        public string Appearance { get; set; } = string.Empty;

        public string BackgroundStatusEducation { get; set; } = string.Empty;

        public string PsychologicalProfile { get; set; } = string.Empty;

        public string SpeechAndCommunication { get; set; } = string.Empty;

        public CharacterProfile Profile { get; private set; } = CharacterProfile.Empty;

        public IReadOnlyDictionary<string, string> AliasExamples { get; private set; } =
            new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        public static EditableCharacterDossier From(CharacterDossier? dossier)
        {
            if (dossier is null)
            {
                return new EditableCharacterDossier();
            }

            var profile = CharacterProfile.Normalize(dossier.Profile);
            return new EditableCharacterDossier
            {
                CharacterId = dossier.CharacterId,
                Name = dossier.Name,
                Description = dossier.Description,
                Gender = AllowedGenders.Contains(dossier.Gender) ? dossier.Gender : UnknownGender,
                ImportanceLevel = CharacterImportance.NormalizeLevel(dossier.ImportanceLevel),
                Appearance = profile.Appearance,
                BackgroundStatusEducation = profile.BackgroundStatusEducation,
                PsychologicalProfile = profile.PsychologicalProfile,
                SpeechAndCommunication = profile.SpeechAndCommunication,
                Profile = profile,
                AliasExamples = new Dictionary<string, string>(dossier.AliasExamples, StringComparer.OrdinalIgnoreCase),
            };
        }
    }

    private sealed class AliasRow(string alias = "", string example = "")
    {
        public string Alias { get; set; } = alias;

        public string Example { get; set; } = example;
    }

    private sealed class RoleBondRow(string characterName = "", string role = "", string description = "")
    {
        public string CharacterName { get; set; } = characterName;

        public string Role { get; set; } = role;

        public string Description { get; set; } = description;
    }

    }
