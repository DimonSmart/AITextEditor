@page "/character-bible"
@implements IDisposable
@using AiTextEditor.Core.Model
@using AiTextEditor.Web.Components.Dialogs
@inject EditorWorkspaceState Workspace
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Character Bible</PageTitle>

<section class="character-bible-page">
    <div class="character-bible-toolbar">
        <div class="character-bible-filters">
            <MudText Typo="Typo.body2" Class="character-count character-bible-toolbar-count">
                @FilteredCharacters.Count of @characters.Count characters
            </MudText>
            <MudTextField @bind-Value="searchQuery"
                          Placeholder="Search characters..."
                          Variant="MudBlazor.Variant.Outlined"
                          Margin="MudBlazor.Margin.Dense"
                          Immediate="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" />
            <MudSelect T="string"
                       @bind-Value="genderFilter"
                       Label="Gender"
                       Variant="MudBlazor.Variant.Outlined"
                       Margin="MudBlazor.Margin.Dense">
                <MudSelectItem T="string" Value="@AllGenders">All</MudSelectItem>
                <MudSelectItem T="string" Value="@MaleGender">Male</MudSelectItem>
                <MudSelectItem T="string" Value="@FemaleGender">Female</MudSelectItem>
                <MudSelectItem T="string" Value="@UnknownGender">Unknown</MudSelectItem>
            </MudSelect>
            <MudCheckBox T="bool"
                         @bind-Value="onlyIncomplete"
                         Label="Only incomplete"
                         Color="MudBlazor.Color.Primary" />
        </div>
        <div class="character-bible-actions">
            <MudButton Variant="MudBlazor.Variant.Filled"
                       Color="MudBlazor.Color.Primary"
                       StartIcon="@Icons.Material.Filled.PersonAdd"
                       Disabled="@Workspace.IsReadOnly"
                       OnClick="AddCharacterAsync">
                Add character
            </MudButton>
            <MudButton Variant="MudBlazor.Variant.Outlined"
                       Color="MudBlazor.Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save"
                       Disabled="@(Workspace.IsReadOnly || isSaving)"
                       OnClick="SaveCharacterBibleAsync">
                @SaveButtonText
            </MudButton>
        </div>
    </div>

    @if (characters.Count == 0)
    {
        <MudPaper Class="empty-state character-bible-empty" Outlined="true">
            <MudIcon Icon="@Icons.Material.Filled.Groups" Size="MudBlazor.Size.Large" />
            <MudText Typo="Typo.h6">No characters yet.</MudText>
            <MudText Typo="Typo.body2">Add a character or run a character bible operation.</MudText>
        </MudPaper>
    }
    else if (FilteredCharacters.Count == 0)
    {
        <MudPaper Class="empty-state character-bible-empty" Outlined="true">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="MudBlazor.Size.Large" />
            <MudText Typo="Typo.h6">No characters found</MudText>
            <MudText Typo="Typo.body2">Try changing the search query or filters.</MudText>
        </MudPaper>
    }
    else
    {
        <div class="character-grid">
            @foreach (var dossier in FilteredCharacters)
            {
                <CharacterCard Dossier="dossier"
                               IsSelected="@(selectedCharacterId == dossier.CharacterId)"
                               IsReadOnly="@Workspace.IsReadOnly"
                               OnSelected="SelectCharacter"
                               OnEdit="EditCharacterAsync"
                               OnDelete="DeleteCharacterAsync" />
            }
        </div>
    }
</section>

@code {
    private const string AllGenders = "all";
    private const string UnknownGender = "unknown";
    private const string MaleGender = "male";
    private const string FemaleGender = "female";

    private static readonly DialogOptions EditDialogOptions = new()
    {
        FullWidth = true,
        MaxWidth = MaxWidth.Medium,
        CloseButton = true
    };

    private static readonly DialogOptions DeleteDialogOptions = new()
    {
        FullWidth = true,
        MaxWidth = MaxWidth.ExtraSmall
    };

    private List<CharacterDossier> characters = [];
    private string searchQuery = string.Empty;
    private string genderFilter = AllGenders;
    private bool onlyIncomplete;
    private bool isSaving;
    private bool hasUnsavedChanges;
    private bool hasSavedSuccessfully;
    private string? selectedCharacterId;

    private IReadOnlyList<CharacterDossier> FilteredCharacters =>
        CharacterDossierSearch.Filter(characters, searchQuery, genderFilter, onlyIncomplete);

    private string SaveButtonText =>
        isSaving ? "Saving..." :
        hasUnsavedChanges ? "Unsaved changes" :
        hasSavedSuccessfully ? "Saved" :
        "Save";

    protected override void OnInitialized()
    {
        Workspace.Changed += OnWorkspaceChanged;
        RefreshCards();
    }

    private async Task AddCharacterAsync()
    {
        if (Workspace.IsReadOnly)
        {
            return;
        }

        await OpenEditorAsync(null);
    }

    private async Task EditCharacterAsync(CharacterDossier dossier)
    {
        if (Workspace.IsReadOnly)
        {
            return;
        }

        await OpenEditorAsync(dossier);
    }

    private async Task OpenEditorAsync(CharacterDossier? dossier)
    {
        var title = dossier is null ? "Add character" : $"Edit {dossier.Name}";
        var parameters = new DialogParameters<CharacterDossierEditDialog>
        {
            { dialog => dialog.Dossier, dossier }
        };

        var dialog = await DialogService.ShowAsync<CharacterDossierEditDialog>(title, parameters, EditDialogOptions);
        var result = await dialog.Result;
        if (result?.Canceled != false || result.Data is not CharacterDossier updatedDossier)
        {
            return;
        }

        Workspace.UpsertCharacterDossier(updatedDossier);
        selectedCharacterId = updatedDossier.CharacterId;
        RefreshCards();
        hasUnsavedChanges = true;
        await SaveAfterChangeAsync("Character saved.");
    }

    private async Task DeleteCharacterAsync(CharacterDossier dossier)
    {
        if (Workspace.IsReadOnly)
        {
            return;
        }

        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete character",
            $"Delete \"{dossier.Name}\" from the character bible?",
            "Delete",
            "Cancel",
            null,
            DeleteDialogOptions);

        if (confirmed != true)
        {
            return;
        }

        if (Workspace.RemoveCharacterDossier(dossier.CharacterId))
        {
            if (selectedCharacterId == dossier.CharacterId)
            {
                selectedCharacterId = null;
            }

            RefreshCards();
            hasUnsavedChanges = true;
            await SaveAfterChangeAsync("Character deleted.");
        }
    }

    private async Task SaveCharacterBibleAsync()
    {
        if (Workspace.IsReadOnly)
        {
            return;
        }

        await SaveAfterChangeAsync($"Saved character bible: {Workspace.CurrentCharacterBiblePath}");
    }

    private async Task SaveAfterChangeAsync(string successMessage)
    {
        isSaving = true;
        try
        {
            await Workspace.SaveCharacterBibleAsync();
            hasUnsavedChanges = false;
            hasSavedSuccessfully = true;
            Snackbar.Add(successMessage, MudBlazor.Severity.Success);
        }
        catch (InvalidOperationException)
        {
            hasUnsavedChanges = true;
            Snackbar.Add("Character changed in memory. No book disk path is set yet.", MudBlazor.Severity.Warning);
        }
        catch (Exception ex)
        {
            hasUnsavedChanges = true;
            Snackbar.Add(ex.Message, MudBlazor.Severity.Error);
        }
        finally
        {
            isSaving = false;
        }
    }

    private void RefreshCards()
    {
        characters = Workspace.CharacterDossiers
            .GetDossiers()
            .Characters
            .OrderBy(dossier => dossier.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private void SelectCharacter(CharacterDossier dossier)
    {
        selectedCharacterId = dossier.CharacterId;
    }

    private void OnWorkspaceChanged()
    {
        RefreshCards();
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Workspace.Changed -= OnWorkspaceChanged;
    }
}
