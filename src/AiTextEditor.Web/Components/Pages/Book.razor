@page "/"
@page "/book"
@implements IDisposable
@inject EditorWorkspaceState Workspace
@inject IProgramSettingsStore SettingsStore
@inject ISnackbar Snackbar

<PageTitle>Book</PageTitle>

<div class="book-file-bar">
    <MudTextField @bind-Value="bookPath"
                  Label="Book path"
                  Variant="MudBlazor.Variant.Outlined"
                  Margin="MudBlazor.Margin.Dense"
                  Immediate="true"
                  Disabled="@Workspace.IsReadOnly" />
    <MudButton Variant="MudBlazor.Variant.Filled"
               Color="MudBlazor.Color.Primary"
               StartIcon="@Icons.Material.Filled.FolderOpen"
               Disabled="@(Workspace.IsReadOnly || string.IsNullOrWhiteSpace(bookPath))"
               OnClick="LoadBookFromPathAsync">
        Load Book
    </MudButton>
    <MudButton Variant="MudBlazor.Variant.Filled"
               Color="MudBlazor.Color.Secondary"
               StartIcon="@Icons.Material.Filled.Save"
               Disabled="@(Workspace.IsReadOnly || string.IsNullOrWhiteSpace(Workspace.CurrentBookPath))"
               OnClick="SaveBookAsync">
        Save
    </MudButton>
</div>

<MarkdownSplitEditor Title="Markdown" Value="@markdown" ValueChanged="OnMarkdownChangedAsync" ReadOnly="@Workspace.IsReadOnly" />

@code {
    private string markdown = string.Empty;
    private string bookPath = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        Workspace.Changed += OnWorkspaceChanged;
        markdown = Workspace.CurrentMarkdown;
        try
        {
            var settings = await SettingsStore.LoadAsync(CancellationToken.None);
            bookPath = Workspace.CurrentBookPath ?? settings.LastBookPath ?? string.Empty;
        }
        catch (Exception ex)
        {
            bookPath = Workspace.CurrentBookPath ?? string.Empty;
            Snackbar.Add(ex.Message, MudBlazor.Severity.Error);
        }
    }

    private Task OnMarkdownChangedAsync(string value)
    {
        if (Workspace.IsReadOnly)
        {
            return Task.CompletedTask;
        }

        markdown = value;
        try
        {
            Workspace.LoadMarkdown(markdown);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, MudBlazor.Severity.Error);
        }

        return Task.CompletedTask;
    }

    private async Task LoadBookFromPathAsync()
    {
        if (Workspace.IsReadOnly)
        {
            return;
        }

        try
        {
            var resolvedBookPath = bookPath.Trim();
            await Workspace.LoadBookAsync(resolvedBookPath);
            markdown = Workspace.CurrentMarkdown;
            bookPath = Workspace.CurrentBookPath ?? bookPath;
            await SaveLastBookPathAsync(bookPath);
            var loadMessage = Workspace.CurrentCharacterBibleLoadedFromFile
                ? $"Loaded book and character bible: {Workspace.CurrentCharacterBiblePath}"
                : $"Loaded book. Character bible file was not found, using empty dossiers: {Workspace.CurrentCharacterBiblePath}";
            Snackbar.Add(loadMessage, MudBlazor.Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, MudBlazor.Severity.Error);
        }
    }

    private async Task SaveLastBookPathAsync(string loadedBookPath)
    {
        var settings = await SettingsStore.LoadAsync(CancellationToken.None);
        settings.LastBookPath = loadedBookPath;
        await SettingsStore.SaveAsync(settings, CancellationToken.None);
    }

    private async Task SaveBookAsync()
    {
        if (Workspace.IsReadOnly)
        {
            return;
        }

        try
        {
            await Workspace.SaveBookAsync();
            Snackbar.Add($"Saved book and character bible: {Workspace.CurrentCharacterBiblePath}", MudBlazor.Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, MudBlazor.Severity.Error);
        }
    }

    private void OnWorkspaceChanged()
    {
        markdown = Workspace.CurrentMarkdown;
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Workspace.Changed -= OnWorkspaceChanged;
    }
}
