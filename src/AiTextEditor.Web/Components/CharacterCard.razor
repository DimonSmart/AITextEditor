@using AiTextEditor.Core.Model

<MudCard Class="@CardClass" Outlined="true">
    <MudCardContent>
        @if (IsExpanded)
        {
            <CharacterFullBody Dossier="Dossier"
                               OnToggleExpanded="ToggleExpandedAsync" />
        }
        else
        {
            <CharacterCompactBody Dossier="Dossier"
                                  OnToggleExpanded="ToggleExpandedAsync" />
        }
    </MudCardContent>
    <MudCardActions Class="character-card-actions">
        @if (IsExpanded)
        {
            <MudButton Variant="MudBlazor.Variant.Text"
                       Color="MudBlazor.Color.Primary"
                       Size="MudBlazor.Size.Small"
                       StartIcon="@Icons.Material.Filled.ExpandLess"
                       OnClick="ToggleExpandedAsync">
                Collapse
            </MudButton>
        }
        else
        {
            <MudButton Variant="MudBlazor.Variant.Text"
                       Color="MudBlazor.Color.Primary"
                       Size="MudBlazor.Size.Small"
                       StartIcon="@Icons.Material.Filled.Visibility"
                       OnClick="ToggleExpandedAsync">
                View
            </MudButton>
        }
        <MudButton Variant="MudBlazor.Variant.Text"
                   Color="MudBlazor.Color.Primary"
                   Size="MudBlazor.Size.Small"
                   StartIcon="@Icons.Material.Filled.Edit"
                   Disabled="@IsReadOnly"
                   OnClick="EditAsync">
            Edit
        </MudButton>
        <MudButton Variant="MudBlazor.Variant.Text"
                   Color="MudBlazor.Color.Error"
                   Size="MudBlazor.Size.Small"
                   StartIcon="@Icons.Material.Filled.Delete"
                   Disabled="@IsReadOnly"
                   OnClick="DeleteAsync">
            Delete
        </MudButton>
    </MudCardActions>
</MudCard>

@code {
    [Parameter, EditorRequired]
    public CharacterDossier Dossier { get; set; } = null!;

    [Parameter]
    public bool IsExpanded { get; set; }

    [Parameter]
    public bool IsReadOnly { get; set; }

    [Parameter]
    public EventCallback<CharacterDossier> OnEdit { get; set; }

    [Parameter]
    public EventCallback<CharacterDossier> OnDelete { get; set; }

    [Parameter]
    public EventCallback<CharacterDossier> OnToggleExpanded { get; set; }

    private bool IsIncomplete => CharacterDossierSearch.IsIncomplete(Dossier);

    private string CardClass =>
        $"character-card{(IsExpanded ? " character-card-expanded" : "")}{(IsIncomplete ? " character-card-incomplete" : "")}";

    private Task ToggleExpandedAsync()
    {
        return OnToggleExpanded.InvokeAsync(Dossier);
    }

    private Task EditAsync()
    {
        if (IsReadOnly)
        {
            return Task.CompletedTask;
        }

        return OnEdit.InvokeAsync(Dossier);
    }

    private Task DeleteAsync()
    {
        if (IsReadOnly)
        {
            return Task.CompletedTask;
        }

        return OnDelete.InvokeAsync(Dossier);
    }
}
