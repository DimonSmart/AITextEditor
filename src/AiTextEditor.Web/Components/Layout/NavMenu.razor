@inject Microsoft.Extensions.Hosting.IHostApplicationLifetime ApplicationLifetime

<MudDrawerHeader>
    <MudText Typo="Typo.subtitle1">Navigation</MudText>
</MudDrawerHeader>

<MudNavMenu Class="app-nav-menu">
    <MudNavLink Href="book"
                Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.MenuBook">
        Book
    </MudNavLink>
    <MudNavLink Href="items"
                Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.FormatListBulleted">
        Linear Items
    </MudNavLink>
    <MudNavLink Href="character-bible"
                Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Groups">
        Character Bible
    </MudNavLink>
    <MudNavLink Href="bible-operations"
                Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Terminal">
        Bible Operations
    </MudNavLink>
    <MudNavLink Href="settings"
                Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Settings">
        Settings
    </MudNavLink>
    <MudDivider Class="my-2" />
    <MudNavLink Icon="@Icons.Material.Filled.PowerSettingsNew"
                IconColor="MudBlazor.Color.Error"
                OnClick="QuitApplication">
        Quit
    </MudNavLink>
</MudNavMenu>

@code {
    private void QuitApplication()
    {
        ApplicationLifetime.StopApplication();
    }
}
