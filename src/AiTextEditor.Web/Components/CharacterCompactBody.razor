@using AiTextEditor.Core.Model

<div class="character-card-body character-card-compact-body">
    <header class="character-card-header">
        <div class="@AvatarClass" aria-hidden="true">@Initial</div>
        <div class="character-card-title">
            <MudButton Variant="MudBlazor.Variant.Text"
                       Color="MudBlazor.Color.Primary"
                       Size="MudBlazor.Size.Small"
                       Class="character-card-name-button"
                       OnClick="ToggleExpandedAsync"
                       title="@Dossier.Name">
                @DisplayName
            </MudButton>
            <div class="character-card-summary">
                <span class="@GenderBadgeClass">@GenderLabel</span>
                <span>@ImportanceLabel</span>
                <span>@AliasesSummary</span>
                <span>@ProfileCompletenessText</span>
            </div>
        </div>
        @if (IsIncomplete)
        {
            <span class="character-incomplete-badge">Incomplete</span>
        }
    </header>

    <section class="character-profile-preview" aria-label="Profile preview">
        <div class="character-profile-preview-row">
            <span class="character-profile-preview-label">Внешность</span>
            <span class="@ProfileValueClass(Profile.Appearance)" title="@Profile.Appearance">@ProfileText(Profile.Appearance)</span>
        </div>
        <div class="character-profile-preview-row">
            <span class="character-profile-preview-label">Статус и компетенции</span>
            <span class="@ProfileValueClass(Profile.StatusAndCompetence)" title="@Profile.StatusAndCompetence">@ProfileText(Profile.StatusAndCompetence)</span>
        </div>
        <div class="character-profile-preview-row">
            <span class="character-profile-preview-label">Психология</span>
            <span class="@ProfileValueClass(Profile.PsychologicalProfile, clampLines: 2)" title="@Profile.PsychologicalProfile">@ProfileText(Profile.PsychologicalProfile)</span>
        </div>
        <div class="character-profile-preview-row">
            <span class="character-profile-preview-label">Речь</span>
            <span class="@ProfileValueClass(Profile.SpeechAndCommunication)" title="@Profile.SpeechAndCommunication">@ProfileText(Profile.SpeechAndCommunication)</span>
        </div>
    </section>

    <section class="character-aliases" aria-label="Aliases">
        <div class="character-card-section-title">Aliases</div>
        <div class="character-alias-chip-row">
            @if (Dossier.Aliases.Count == 0)
            {
                <span class="character-empty-note">No aliases</span>
            }
            else
            {
                @foreach (var alias in Dossier.Aliases.Take(MaxVisibleAliases))
                {
                    <span class="character-alias-chip" title="@alias">@alias</span>
                }

                @if (HiddenAliasCount > 0)
                {
                    <span class="character-alias-chip character-alias-more">+@HiddenAliasCount more</span>
                }
            }
        </div>
    </section>
</div>

@code {
    private const int MaxVisibleAliases = 3;

    [Parameter, EditorRequired]
    public CharacterDossier Dossier { get; set; } = null!;

    [Parameter]
    public EventCallback OnToggleExpanded { get; set; }

    private bool IsIncomplete => CharacterDossierSearch.IsIncomplete(Dossier);

    private CharacterProfile Profile => CharacterProfile.Normalize(Dossier.Profile);

    private int CompletedProfileSections => CharacterProfile.CountCompletedSections(Profile);

    private int HiddenAliasCount => Math.Max(0, Dossier.Aliases.Count - MaxVisibleAliases);

    private string DisplayName => string.IsNullOrWhiteSpace(Dossier.Name) ? "Unnamed character" : Dossier.Name.Trim();

    private string Initial => string.IsNullOrWhiteSpace(Dossier.Name)
        ? "?"
        : char.ToUpperInvariant(Dossier.Name.Trim()[0]).ToString();

    private string AliasesSummary => CountText(Dossier.Aliases.Count, "alias", "aliases");

    private string ProfileCompletenessText => $"Профиль {CompletedProfileSections}/4";

    private string GenderLabel => Dossier.Gender switch
    {
        "male" => "Male",
        "female" => "Female",
        _ => "Unknown"
    };

    private string ImportanceLabel => CharacterImportance.GetLabel(Dossier.ImportanceLevel);

    private string GenderClass => Dossier.Gender switch
    {
        "male" => "male",
        "female" => "female",
        _ => "unknown"
    };

    private string AvatarClass => $"character-avatar character-avatar-{GenderClass}";

    private string GenderBadgeClass => $"character-gender-badge character-gender-{GenderClass}";

    private Task ToggleExpandedAsync()
    {
        return OnToggleExpanded.InvokeAsync();
    }

    private static string ProfileText(string? value)
        => string.IsNullOrWhiteSpace(value) ? "Не указано" : value.Trim();

    private static string ProfileValueClass(string? value, int clampLines = 1)
    {
        var clampClass = clampLines == 2 ? "character-line-clamp-2" : "character-line-clamp-1";
        var mutedClass = string.IsNullOrWhiteSpace(value) ? " character-profile-preview-muted" : string.Empty;
        return $"character-profile-preview-value {clampClass}{mutedClass}";
    }

    private static string CountText(int count, string singular, string plural)
    {
        return count == 1 ? $"1 {singular}" : $"{count} {plural}";
    }
}
